{
  "manifest_version": 3,
  "name": "one",
  "version": "0.2.0",
  "description": "one 的浏览器执行层:经 WebSocket 接入主域名,用 CDP 操控 Chrome、截图并回传结果。",
  "permissions": ["debugger", "tabs", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "icons": { "32": "icons/icon-32.png", "128": "icons/icon-128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "one",
    "default_icon": { "32": "icons/icon-32.png", "128": "icons/icon-128.png" }
  }
}
