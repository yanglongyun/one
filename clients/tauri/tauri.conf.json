{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "one",
  "version": "0.4.0",
  "identifier": "com.oneapp.one",
  "build": {
    "frontendDist": "web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "one",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"],
    "macOS": {
      "signingIdentity": null,
      "minimumSystemVersion": "11.0"
    }
  }
}
